TRANSCRIBER_TYPE=groq  # groq or local
LLM_TYPE=gemini        # gemini or local

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
API_KEY=your_service_api_key_here

# Local Model Configurations (used if TRANSCRIBER_TYPE=local or LLM_TYPE=local)
LOCAL_WHISPER_URL=http://localhost:8080/v1
LOCAL_WHISPER_MODEL=whisper-large-v3
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=gemma

# Optional: comma-separated Google AI model IDs for generation tasks.
GEMINI_GENERATION_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemma-4-26b-a4b-it

# Optional: tune in-process background queue parallelism.
TRANSCRIBE_WORKERS=4
ANALYSIS_WORKERS=4

# Cloudflare R2 (S3-compatible object storage) for audio chunk uploads.
# Optional: if unset, the service falls back to local temp files, which
# only works when a single ML-service instance handles both the upload
# and the transcription job. Set these to enable R2 so uploads and
# background workers can run on different instances/containers.
#
# 1. In the Cloudflare dashboard: R2 > Create bucket -> note the bucket name.
# 2. R2 > Manage API tokens > Create API token (Object Read & Write,
#    scoped to that bucket) -> copy the Access Key ID and Secret Access Key.
# 3. Account ID is shown on the R2 overview page (or Workers & Pages
#    overview) in the right sidebar.
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=adaptlearning-audio-chunks
# Optional: override the endpoint (defaults to
# https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com). Useful for
# jurisdiction-specific endpoints (e.g. the EU data location).
# R2_ENDPOINT_URL=https://your_cloudflare_account_id.r2.cloudflarestorage.com

